<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>نموذج زيارة رسمي - السفير</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <style>
        :root { --main-gold: #b08d57; --dark-navy: #0a192f; --soft-gray: #f9f9f9; }
        body { font-family: 'Cairo', sans-serif; background-color: #f0f0f0; margin: 0; padding: 20px; }
        
        .paper { 
            width: 210mm; min-height: 285mm; padding: 20mm; margin: auto; 
            background: #fff; position: relative; box-sizing: border-box; 
            border-top: 10px solid var(--dark-navy); box-shadow: 0 0 15px rgba(0,0,0,0.1);
        }

        .watermark { 
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(-30deg); 
            font-size: 130px; font-weight: 900; color: rgba(0,0,0,0.02); z-index: 0; pointer-events: none;
        }

        .header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #eee; padding-bottom: 20px; margin-bottom: 30px; }
        .brand h1 { font-size: 45px; font-weight: 900; color: var(--dark-navy); margin: 0; line-height: 1; }
        .brand span { font-size: 14px; color: var(--main-gold); font-weight: bold; letter-spacing: 2px; }
        
        .doc-meta { text-align: left; font-size: 13px; color: #555; }
        
        .title-box { text-align: center; margin: 30px 0; }
        .title-box h2 { display: inline-block; background: var(--soft-gray); border: 1px solid #ddd; padding: 10px 50px; border-radius: 5px; color: var(--dark-navy); font-size: 22px; }

        .data-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 30px; }
        .data-item { padding: 15px; border-bottom: 1px solid #f0f0f0; border-right: 4px solid var(--main-gold); background: #fcfcfc; }
        .label { font-size: 12px; color: #888; font-weight: bold; }
        .value { font-size: 18px; font-weight: 700; color: var(--dark-navy); margin-top: 5px; }

        .notes-section { margin-top: 30px; border: 1px solid #eee; border-radius: 8px; }
        .notes-head { background: var(--dark-navy); color: white; padding: 10px 20px; font-weight: bold; }
        .notes-body { height: 200px; background-image: linear-gradient(#eee 1.1px, transparent 1.1px); background-size: 100% 30px; }

        .signatures { margin-top: 80px; display: flex; justify-content: space-between; }
        .sig-box { width: 220px; text-align: center; }
        .sig-line { margin-top: 40px; border-top: 2px solid var(--dark-navy); padding-top: 8px; font-weight: 700; }

        .btn-print { position: fixed; top: 20px; left: 20px; background: #27ae60; color: white; border: none; padding: 15px 30px; border-radius: 50px; font-family: 'Cairo'; cursor: pointer; z-index: 100; box-shadow: 0 4px 10px rgba(0,0,0,0.2); }

        @media print { 
            body { background: none; padding: 0; } 
            .paper { box-shadow: none; margin: 0; width: 100%; border-top: 15px solid var(--dark-navy); } 
            .btn-print { display: none; }
        }
    </style>
</head>
<body>

    <button class="btn-print" onclick="window.print()">🖨️ طباعة المستند الرسمي</button>

    <div class="paper">
        <div class="watermark">AL SAFIR</div>

        <div class="header">
            <div class="brand">
                <h1>السفير</h1>
                <span>AL SAFIR AUTOMOTIVE</span>
            </div>
            <div class="doc-meta">
                تاريخ الزيارة: <%= serverTime %><br>
                فرع المعاينة: الرئيسي
            </div>
        </div>

        <div class="title-box">
            <h2>نموذج معاينة وزيارة عميل</h2>
        </div>

        <div class="data-grid">
            <div class="data-item">
                <div class="label">اسم العميل المحترم:</div>
                <div class="value"><%= client.name %></div>
            </div>
            <div class="data-item">
                <div class="label">مسؤول المبيعات:</div>
                <div class="value">أ / <%= client.assignedTo %></div>
            </div>
            <div class="data-item">
                <div class="label">السيارة المهتم بها:</div>
                <div class="value"><%= client.car %></div>
            </div>
            <div class="data-item">
                <div class="label">نوع المعاملة:</div>
                <div class="value"><%= client.purpose %></div>
            </div>
            <div class="data-item" style="grid-column: span 2;">
                <div class="label">مصدر الزيارة:</div>
                <div class="value"><%= client.source %></div>
            </div>
        </div>

        <div class="notes-section">
            <div class="notes-head">ملاحظات مسؤول المبيعات والفحص</div>
            <div class="notes-body"></div>
        </div>

        <div class="signatures">
            <div class="sig-box"><div class="sig-line">ختم الشركة</div></div>
            <div class="sig-box"><div class="sig-line">توقيع العميل</div></div>
        </div>

        <div style="position: absolute; bottom: 0; right: 0; left: 0; height: 5px; background: var(--main-gold);"></div>
    </div>

</body>
</html>