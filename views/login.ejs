<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تسجيل دخول | السفير لاستيراد السيارات</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-dark: #0f172a;
            --accent-gold: #c5a059;
            --glow-color: rgba(197, 160, 89, 0.8);
        }

        body {
            font-family: 'Cairo', sans-serif;
            background: linear-gradient(rgba(15, 23, 42, 0.9), rgba(15, 23, 42, 0.9)),
                        url('https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?q=80&w=1920&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            width: 100%;
            max-width: 420px;
            border-top: 5px solid var(--accent-gold);
            position: relative;
        }

        .logo-container {
            text-align: center;
            margin-bottom: 25px;
        }

        .brand-logo-img {
            width: 110px;
            height: 110px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            border: 3px solid var(--accent-gold);
            padding: 5px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        .brand-logo-img img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .brand-name {
            color: var(--primary-dark);
            font-weight: 900;
            font-size: 24px;
            margin-bottom: 5px;
        }

        .brand-name span {
            color: var(--accent-gold);
        }

        .sub-text {
            color: #64748b;
            font-size: 14px;
            font-weight: 600;
        }

        .form-label {
            font-weight: 700;
            color: var(--primary-dark);
            margin-bottom: 8px;
        }

        .form-control {
            border-radius: 12px;
            padding: 12px;
            border: 2px solid #e2e8f0;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            border-color: var(--accent-gold);
            box-shadow: 0 0 0 0.25rem rgba(197, 160, 89, 0.25);
        }

        .btn-login {
            background: var(--primary-dark);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 16px;
            margin-top: 20px;
            transition: all 0.3s ease;
        }

        .btn-login:hover {
            background: var(--accent-gold);
            color: var(--primary-dark);
            transform: translateY(-2px);
        }

        .footer-text {
            text-align: center;
            margin-top: 30px;
            font-size: 13px;
            color: #94a3b8;
        }

        /* تأثير التوهج الجديد للبشمهندس بلال */
        .glow-link {
            display: inline-block;
            color: var(--accent-gold) !important;
            text-decoration: none;
            font-weight: 900;
            padding: 5px 15px;
            border-radius: 50px;
            border: 1px solid var(--accent-gold);
            transition: all 0.4s ease;
            animation: pulse-glow 2s infinite ease-in-out;
            letter-spacing: 0.5px;
        }

        @keyframes pulse-glow {
            0% {
                box-shadow: 0 0 5px var(--glow-color);
                transform: scale(1);
            }
            50% {
                box-shadow: 0 0 20px var(--glow-color), 0 0 30px var(--glow-color);
                transform: scale(1.05);
                text-shadow: 0 0 8px var(--glow-color);
            }
            100% {
                box-shadow: 0 0 5px var(--glow-color);
                transform: scale(1);
            }
        }

        .glow-link:hover {
            background: var(--accent-gold);
            color: white !important;
            box-shadow: 0 0 25px var(--accent-gold);
            text-shadow: none;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo-container">
            <div class="brand-logo-img">
                <img src="/images/logo.png" alt="لوجو السفير">
            </div>
            <div class="brand-name"><span>السفير</span> لاستيراد السيارات</div>
            <div class="sub-text text-uppercase">نظام إدارة المبيعات واللوجستيات</div>
        </div>

        <% if(typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger text-center">
                <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
            </div>
        <% } %>

        <form action="/login" method="POST">
            <div class="mb-3">
                <label class="form-label">
                    <i class="fas fa-user-circle me-1"></i> اسم المستخدم
                </label>
                <input type="text" name="username" class="form-control" placeholder="أدخل اسم المستخدم" required>
            </div>
            <div class="mb-3">
                <label class="form-label">
                    <i class="fas fa-lock me-1"></i> كلمة المرور
                </label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required>
            </div>
            
            <button type="submit" class="btn btn-login w-100">
                دخول للنظام <i class="fas fa-sign-in-alt ms-2"></i>
            </button>
        </form>

        <div class="footer-text">
            تم التطوير بواسطة <br>
            <a href="https://procoding.vercel.app/" target="_blank" class="glow-link mt-2">
                <i class="fas fa-code me-1"></i> Eng. Belal Hesham
            </a> 
            <div class="mt-2">&copy; 2026</div>
        </div>
    </div>
</body>
</html>