<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>السفير لوجستيك | نظام تتبع العمليات</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    :root {
      --primary-dark: #0f172a;
      --accent-gold: #c5a059;
      --card-bg: rgba(30, 41, 59, 0.7);
    }

    body {
      background: linear-gradient(rgba(15, 23, 42, 0.95), rgba(15, 23, 42, 0.98)),
        url('https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=2015&auto=format&fit=crop') no-repeat center center fixed;
      background-size: cover;
      font-family: 'Cairo', sans-serif;
      color: #fff;
      min-height: 100vh;
    }

    .stat-card {
      background: var(--card-bg);
      border: 1px solid rgba(197, 160, 89, 0.2);
      border-radius: 20px;
      padding: 25px;
      position: relative;
      overflow: hidden;
      transition: 0.3s;
      backdrop-filter: blur(10px);
    }

    .stat-card:hover {
      transform: translateY(-5px);
      border-color: var(--accent-gold);
    }

    .stat-icon {
      position: absolute;
      left: -10px;
      bottom: -10px;
      font-size: 5rem;
      opacity: 0.1;
      color: var(--accent-gold);
    }

    .chart-container {
      background: var(--card-bg);
      border-radius: 25px;
      padding: 25px;
      border: 1px solid rgba(255, 255, 255, 0.05);
      margin-bottom: 30px;

      /* 🔥 الحل هنا: تحديد طول ثابت ومقيد 🔥 */
      height: 400px;
      /* أو أي طول يناسبك، مثلاً 350px */
      position: relative;
      /* ضروري لـ Chart.js */
      overflow: hidden;
      /* يمنع أي محتوى يخرج بره الكارت */
    }

    .activity-feed {
      max-height: 400px;
      overflow-y: auto;
      padding-right: 10px;
    }

    .activity-item {
      border-right: 3px solid var(--accent-gold);
      padding: 10px 15px;
      margin-bottom: 15px;
      background: rgba(255, 255, 255, 0.03);
      border-radius: 0 10px 10px 0;
    }

    @media print {
      .no-print {
        display: none;
      }

      body {
        background: #fff !important;
        color: #000 !important;
      }
    }
  </style>
</head>

<body>
  <nav class="navbar navbar-dark bg-transparent no-print py-3">
    <div class="container">
      <a class="navbar-brand fw-black fs-3" href="/"><i class="fas fa-crown text-warning me-2"></i>السفير</a>
      <span class="text-white-50 small">مرحباً: <b><%= user.name %></b></span>
    </div>
  </nav>

  <div class="container mt-4">
    <div class="row g-4 mb-5">
      <div class="col-md-3">
        <div class="stat-card">
          <i class="fas fa-users stat-icon"></i>
          <h6 class="text-white-50 small">قاعدة البيانات</h6>
          <h2 class="fw-black"><%= stats.totalClients %></h2>
        </div>
      </div>
      <div class="col-md-3">
        <div class="stat-card">
          <i class="fas fa-exchange-alt stat-icon"></i>
          <h6 class="text-white-50 small">حركات السيستم</h6>
          <h2 class="fw-black text-info"><%= stats.statusTransitions %></h2>
        </div>
      </div>
      <div class="col-md-3">
        <div class="stat-card">
          <i class="fas fa-check-circle stat-icon"></i>
          <h6 class="text-white-50 small">التعاقدات</h6>
          <h2 class="fw-black text-warning"><%= stats.successfulDeals %></h2>
        </div>
      </div>
      <div class="col-md-3">
        <div class="stat-card">
          <i class="fas fa-coins stat-icon"></i>
          <h6 class="text-white-50 small">الميزانية الإجمالية</h6>
          <h4 class="fw-black text-success mt-2"><%= stats.totalBudget %></h4>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-lg-4">
        <div class="chart-container">
          <h5 class="fw-bold mb-4"><i class="fas fa-history me-2 text-warning"></i> آخر النشاطات</h5>
          <div class="activity-feed">
            <% stats.recentActivity.forEach(log => { %>
            <div class="activity-item">
              <div class="d-flex justify-content-between">
                <small class="text-warning fw-bold"><%= log.clientName %></small>
                <small class="text-white-50"><%= log.date %></small>
              </div>
              <p class="small mb-0">الحالة: <%= log.newStatus %></p>
              <small class="text-white-50">بواسطة: <%= log.user %></small>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
      <<div class="col-lg-8">
        <div class="chart-container">
          <h5 class="fw-bold mb-4"><i class="fas fa-chart-area me-2 text-warning"></i> تحليل التدفق</h5>
          <canvas id="statusChart"></canvas>
        </div>
    </div>
  </div>

  <div class="chart-container mt-4">
    <h5 class="fw-bold mb-4">كفاءة المناديب</h5>
    <div class="table-responsive">
      <table class="table table-hover text-white">
        <thead>
          <tr>
            <th>الموظف</th>
            <th>العملاء</th>
            <th>التعاقدات</th>
            <th>الميزانية</th>
            <th>الكفاءة</th>
          </tr>
        </thead>
        <tbody>
          <% stats.employeePerformance.forEach(emp => { %>
          <tr>
            <td><%= emp.name %></td>
            <td><%= emp.clientsCount %></td>
            <td><%= emp.closedDeals %></td>
            <td class="text-info"><%= emp.totalValue %> ج.م</td>
            <td>
              <div class="progress" style="height: 8px;">
                <div class="progress-bar bg-warning" style="width: <%= emp.ratio %>%"></div>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  </div>

  <script>
    const statsData = <%- JSON.stringify(stats) %>;
  </script>
  <script src="/js/dashboard.js"></script>
</body>

</html>